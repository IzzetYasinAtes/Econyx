@inherits LayoutComponentBase
@implements IDisposable
@using System.Globalization
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Nav
@inject PersistentComponentState PersistState

<div class="econyx-root">
    <nav class="econyx-nav">
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">@L["Nav_Dashboard"]</NavLink>
        <NavLink class="nav-item" href="positions">@L["Nav_Positions"]</NavLink>
        <NavLink class="nav-item" href="trades">@L["Nav_Trades"]</NavLink>
        <NavLink class="nav-item" href="settings">@L["Nav_Settings"]</NavLink>
        <select class="lang-select" value="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
                @onchange="OnCultureChanged">
            <option value="en">EN</option>
            <option value="tr">TR</option>
        </select>
    </nav>

    <main class="econyx-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @L["Error_Unhandled"]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">&#x1f5d9;</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;

    protected override void OnInitialized()
    {
        if (PersistState.TryTakeFromJson<string>("culture", out var culture) && !string.IsNullOrEmpty(culture))
        {
            var ci = CultureInfo.GetCultureInfo(culture);
            CultureInfo.CurrentCulture = ci;
            CultureInfo.CurrentUICulture = ci;
        }

        _subscription = PersistState.RegisterOnPersisting(() =>
        {
            PersistState.PersistAsJson("culture", CultureInfo.CurrentUICulture.Name);
            return Task.CompletedTask;
        });
    }

    private void OnCultureChanged(ChangeEventArgs e)
    {
        var culture = e.Value?.ToString() ?? "en";
        var uri = new Uri(Nav.Uri).PathAndQuery;
        Nav.NavigateTo($"Culture/Set?culture={culture}&returnUrl={Uri.EscapeDataString(uri)}", forceLoad: true);
    }

    public void Dispose() => _subscription.Dispose();
}
