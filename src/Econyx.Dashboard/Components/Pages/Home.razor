@page "/"
@using ApexCharts
@using Econyx.Application.Queries.GetBalanceHistory
@inject IMediator Mediator
@implements IDisposable
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Home_Title"]</PageTitle>

@if (_stats is null)
{
    <div class="loading">@L["Loading"]</div>
}
else
{
    <div class="dashboard">

        <div class="top-bar">
            <div class="top-bar-left">
                <span class="agent-title mono">@L["Home_Agent"]</span>
                <span class="agent-mode mono text-muted">//</span>
                <span class="agent-mode mono text-yellow">@L["Home_SurvivalMode"]</span>
                <span class="status-dot"></span>
                <span class="status-text mono text-green">@L["Home_Alive"]</span>
            </div>
            <div class="top-bar-right mono">
                <span class="text-muted">@L["Home_Uptime"]</span>
                <span>@FormatUptime(_stats.Uptime)</span>
                <span class="text-muted" style="margin-left: 1rem;">@L["Home_Cycle"]</span>
                <span>#@_stats.CycleCount</span>
            </div>
        </div>

        <div class="metric-cards">
            <StatsCard Title="@L["Home_CurrentBalance"]"
                       Value="@FormatMoney(_stats.Balance)"
                       SubText="@($"{L["Home_Initial"]}: ${_initialBalance:F2}")" />
            <StatsCard Title="@L["Home_TotalPnl"]"
                       Value="@FormatMoneyPnL(_stats.TotalPnL)"
                       ValueColor="@PnLColor(_stats.TotalPnL.Amount)"
                       SubText="@FormatPnLPercent()" />
            <StatsCard Title="@L["Home_WinRate"]"
                       Value="@($"{_stats.WinRate:F1}%")"
                       ValueColor="@(_stats.WinRate >= 50 ? "var(--green)" : "var(--red)")"
                       SubText="@WinLossText()" />
            <StatsCard Title="@L["Home_AvgEdge"]"
                       Value="@($"{_stats.AvgEdge:F1}%")"
                       ValueColor="@(_stats.AvgEdge >= 0 ? "var(--green)" : "var(--red)")"
                       SubText="@($"{L["Home_MarketsScanned"]}: {_stats.MarketsScanned}")" />
        </div>

        <div class="main-area">
            <div class="main-left">
                <div class="chart-panel">
                    <div class="chart-header">
                        <span class="mono">@L["Home_BalanceHistory"]</span>
                        <span class="mono text-muted">@FormatUptime(_stats.Uptime) / 48H</span>
                    </div>
                    <div class="chart-wrapper">
                        @if (_balanceHistory.Count > 0)
                        {
                            <ApexChart TItem="BalanceHistoryPoint"
                                       Options="_chartOptions"
                                       Height="@("100%")"
                                       Width="@("100%")"
                                       >
                                <ApexPointSeries TItem="BalanceHistoryPoint"
                                                 Items="_balanceHistory"
                                                 SeriesType="SeriesType.Area"
                                                 Name="Total Portfolio"
                                                 XValue="@(p => p.Timestamp.ToString("HH:mm"))"
                                                 YValue="@(p => p.Balance)" />
                            </ApexChart>
                        }
                        else
                        {
                            <span class="text-muted mono" style="margin: auto;">@L["Home_ChartPlaceholder"]</span>
                        }
                    </div>
                </div>
            </div>
            <div class="main-right">
                <ActivityLog Entries="_activityLog" />
            </div>
        </div>

        <div class="bottom-bar mono">
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_Trades"]</span>
                <span>@_stats.TotalTrades</span>
            </div>
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_MarketsScanned"]</span>
                <span>@_stats.MarketsScanned</span>
            </div>
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_OpenPositions"]</span>
                <span>@_stats.OpenPositions</span>
            </div>
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_BestTrade"]</span>
                <span class="text-green">@FormatMoney(_stats.BestTrade)</span>
            </div>
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_WorstTrade"]</span>
                <span class="text-red">@FormatMoney(_stats.WorstTrade)</span>
            </div>
            <div class="bottom-stat">
                <span class="text-muted">@L["Home_SharpeRatio"]</span>
                <span>@_stats.SharpeRatio.ToString("F2")</span>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStatsDto? _stats;
    private Timer? _timer;
    private decimal _initialBalance = 50m;
    private List<ActivityLogEntry> _activityLog = [];
    private List<BalanceHistoryPoint> _balanceHistory = [];

    private ApexChartOptions<BalanceHistoryPoint> _chartOptions = new()
    {
        Chart = new Chart
        {
            Background = "transparent",
            ForeColor = "#8b949e",
            Toolbar = new Toolbar { Show = false },
            Sparkline = new ChartSparkline { Enabled = false },
            Animations = new Animations
            {
                Enabled = true,
                Easing = Easing.Easeinout,
                Speed = 600
            },
            Zoom = new Zoom { Enabled = false }
        },
        Colors = ["#3fb950"],
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 },
        Fill = new Fill
        {
            Type = new List<FillType> { FillType.Gradient },
            Gradient = new FillGradient
            {
                ShadeIntensity = 1,
                OpacityFrom = 0.35,
                OpacityTo = 0.02,
                Stops = [0, 95, 100]
            }
        },
        DataLabels = new DataLabels { Enabled = false },
        Markers = new Markers { Size = 0 },
        Grid = new Grid
        {
            Show = true,
            BorderColor = "#21262d",
            StrokeDashArray = 3,
            Padding = new Padding { Left = 10, Right = 10, Top = 0, Bottom = 0 }
        },
        Xaxis = new XAxis
        {
            Labels = new XAxisLabels
            {
                Style = new AxisLabelStyle { FontSize = "10px", FontFamily = "var(--font-mono)" },
                RotateAlways = false
            },
            AxisTicks = new AxisTicks { Show = false }
        },
        Yaxis =
        [
            new YAxis
            {
                Labels = new YAxisLabels
                {
                    Formatter = @"function(val) { return '$' + val.toFixed(2); }",
                    Style = new AxisLabelStyle { FontSize = "10px", FontFamily = "var(--font-mono)" }
                }
            }
        ],
        Tooltip = new Tooltip
        {
            Theme = Mode.Dark,
            X = new TooltipX { Show = true },
            Y = new TooltipY
            {
                Formatter = @"function(val) { return '$' + val.toFixed(2); }"
            }
        }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
        _timer = new Timer(async _ => await RefreshStats(), null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task LoadStats()
    {
        try
        {
            _stats = await Mediator.Send(new GetDashboardStatsQuery());
            _balanceHistory = (await Mediator.Send(new GetBalanceHistoryQuery())).ToList();
            _activityLog.Add(new ActivityLogEntry(DateTime.Now, L["Home_DataLoaded"], "#3fb950"));
        }
        catch (Exception ex)
        {
            _activityLog.Add(new ActivityLogEntry(DateTime.Now, $"{L["Error_Title"]}: {ex.Message}", "#f85149"));
        }
    }

    private async Task RefreshStats()
    {
        await LoadStats();
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatMoney(Money m) => $"${m.Amount:F2}";

    private static string FormatMoneyPnL(Money pnl) => FormatPnL(pnl.Amount);

    private string FormatPnLPercent()
    {
        if (_stats is null || _initialBalance == 0) return "";
        var pct = (_stats.TotalPnL.Amount / _initialBalance) * 100;
        return pct >= 0 ? $"+{pct:F1}%" : $"{pct:F1}%";
    }

    private static string PnLColor(decimal amount) =>
        amount >= 0 ? "var(--green)" : "var(--red)";

    private string WinLossText()
    {
        if (_stats is null) return "";
        var wins = (int)(_stats.TotalTrades * _stats.WinRate / 100);
        var losses = _stats.TotalTrades - wins;
        return $"{wins}W / {losses}L";
    }

    private static string FormatUptime(TimeSpan ts) =>
        ts.TotalHours >= 1 ? $"{ts.TotalHours:F1}H" : $"{ts.TotalMinutes:F0}M";

    public void Dispose() => _timer?.Dispose();
}
