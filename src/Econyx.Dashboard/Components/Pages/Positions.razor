@page "/positions"
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Positions_Title"]</PageTitle>

<div class="page-header">
    <h2 class="page-title mono">@L["Positions_Header"]</h2>
    <button class="refresh-btn mono" @onclick="LoadPositions">@L["Refresh"]</button>
</div>

@if (_positions is null)
{
    <div class="loading mono text-muted">@L["Loading"]</div>
}
else if (_positions.Count == 0)
{
    <div class="empty-state mono text-muted">@L["Positions_Empty"]</div>
}
else
{
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>@L["Trades_Market"]</th>
                    <th>@L["Trades_Side"]</th>
                    <th>@L["Trades_Entry"]</th>
                    <th>@L["Positions_Current"]</th>
                    <th>@L["Trades_Qty"]</th>
                    <th>Cost</th>
                    <th>@L["Trades_PnL"]</th>
                    <th>@L["Trades_Strategy"]</th>
                    <th>@L["Positions_Opened"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _positions)
                {
                    <tr>
                        <td class="col-question" title="@p.MarketQuestion">@Truncate(p.MarketQuestion, 60)</td>
                        <td>
                            <span class="side-badge @(p.Side == TradeSide.Yes ? "side-yes" : "side-no")">
                                @p.Side
                            </span>
                        </td>
                        <td class="mono">$@p.EntryPrice.Amount.ToString("F4")</td>
                        <td class="mono">$@p.CurrentPrice.Amount.ToString("F4")</td>
                        <td class="mono">@p.Quantity.ToString("N0")</td>
                        <td class="mono">$@((p.EntryPrice.Amount * p.Quantity).ToString("F2"))</td>
                        <td class="mono @PnLClass(p.UnrealizedPnL.Amount)">
                            @FormatPnL(p.UnrealizedPnL.Amount)
                        </td>
                        <td class="text-muted">@p.StrategyName</td>
                        <td class="mono text-muted">@p.OpenedAt.ToLocalTime().ToString("MM/dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<PositionDto>? _positions;

    protected override async Task OnInitializedAsync() => await LoadPositions();

    private async Task LoadPositions()
    {
        try { _positions = await Mediator.Send(new GetOpenPositionsQuery()); }
        catch { _positions = []; }
    }

}
