@page "/trades"
@inject IMediator Mediator
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Trades_Title"]</PageTitle>

<div class="page-header">
    <h2 class="page-title mono">@L["Trades_Header"]</h2>
    <span class="text-muted mono" style="font-size: 0.75rem;">
        @if (_history is not null)
        {
            @string.Format(System.Globalization.CultureInfo.InvariantCulture, L["Trades_TotalCount"], _history.TotalCount)
        }
    </span>
</div>

@if (_history is null)
{
    <div class="loading mono text-muted">@L["Loading"]</div>
}
else if (_history.Items.Count == 0)
{
    <div class="empty-state mono text-muted">@L["Trades_Empty"]</div>
}
else
{
    <div class="trades-layout">
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>@L["Trades_Market"]</th>
                        <th>@L["Trades_Side"]</th>
                        <th>@L["Trades_Entry"]</th>
                        <th>@L["Trades_Exit"]</th>
                        <th>@L["Trades_Qty"]</th>
                        <th>@L["Trades_PnL"]</th>
                        <th>@L["Trades_Duration"]</th>
                        <th>@L["Trades_Strategy"]</th>
                        <th>@L["Trades_Closed"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _history.Items)
                    {
                        <tr>
                            <td class="col-question" title="@t.MarketQuestion">@Truncate(t.MarketQuestion, 50)</td>
                            <td>
                                <span class="side-badge @(t.Side == TradeSide.Yes ? "side-yes" : "side-no")">
                                    @t.Side
                                </span>
                            </td>
                            <td class="mono">$@t.EntryPrice.Amount.ToString("F4")</td>
                            <td class="mono">$@t.ExitPrice.Amount.ToString("F4")</td>
                            <td class="mono">@t.Quantity.ToString("N0")</td>
                            <td class="mono @PnLClass(t.PnL.Amount)">@FormatPnL(t.PnL.Amount)</td>
                            <td class="mono text-muted">@FormatDuration(t.Duration)</td>
                            <td class="text-muted">@t.StrategyName</td>
                            <td class="mono text-muted">@t.ClosedAt.ToLocalTime().ToString("MM/dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_totalPages > 1)
        {
            <div class="pagination mono">
                <button class="page-btn" disabled="@(_page <= 1)" @onclick="PrevPage">@L["Prev"]</button>
                <span class="text-muted">@_page / @_totalPages</span>
                <button class="page-btn" disabled="@(_page >= _totalPages)" @onclick="NextPage">@L["Next"]</button>
            </div>
        }
    </div>
}

@code {
    private TradeHistoryDto? _history;
    private int _page = 1;
    private const int PageSize = 20;
    private int _totalPages => _history is null ? 1 : Math.Max(1, (int)Math.Ceiling(_history.TotalCount / (double)PageSize));

    protected override async Task OnInitializedAsync() => await LoadTrades();

    private async Task LoadTrades()
    {
        try { _history = await Mediator.Send(new GetTradeHistoryQuery(PageSize, _page)); }
        catch { _history = new TradeHistoryDto([], 0); }
    }

    private async Task PrevPage() { _page = Math.Max(1, _page - 1); await LoadTrades(); }
    private async Task NextPage() { _page = Math.Min(_totalPages, _page + 1); await LoadTrades(); }

    private static string FormatDuration(TimeSpan ts) => ts.TotalHours >= 1
        ? $"{ts.TotalHours:F1}h"
        : $"{ts.TotalMinutes:F0}m";
}
