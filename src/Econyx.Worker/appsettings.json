{
  "Trading": {
    "Mode": "Paper",
    "InitialBalance": 50.0,
    "ScanIntervalMinutes": 5,
    "MaxOpenPositions": 10,
    "MaxPositionSizePercent": 5.0,
    "MinEdgeThreshold": 0.06,
    "MinVolumeUsd": 5000,
    "MaxSpreadCents": 5,
    "StopLossPercent": 15.0,
    "TakeProfitPercent": 25.0,
    "SurvivalModeThresholdUsd": 10.0
  },
  "AI": {
    "Provider": "OpenRouter",
    "OpenRouter": {
      "BaseUrl": "https://openrouter.ai/api/v1",
      "DefaultModel": "anthropic/claude-sonnet-4-20250514",
      "MaxTokens": 4096,
      "ApiKeySecretName": "openrouter-api-key",
      "ModelCacheMinutes": 60
    },
    "Claude": { "Model": "claude-sonnet-4-20250514", "MaxTokens": 4096, "ApiKeySecretName": "ai-claude-apikey" },
    "OpenAI": { "Model": "gpt-4o", "MaxTokens": 4096, "ApiKeySecretName": "ai-openai-apikey" },
    "CacheDurationMinutes": 30,
    "MaxConcurrentRequests": 3
  },
  "Platforms": {
    "Polymarket": {
      "BaseUrl": "https://clob.polymarket.com",
      "GammaBaseUrl": "https://gamma-api.polymarket.com",
      "ChainId": 137,
      "PrivateKeySecretName": "polymarket-private-key",
      "SignatureType": 0
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=EconyxDb;User Id=sa;Password=Your_Password_Here;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/econyx-.log", "rollingInterval": "Day" } }
    ]
  }
}
